# ==============================================================================
# Rocket.Chat Replacement Backend - Environment Configuration
# ==============================================================================

# Server Core Settings
PORT=8080
ENV=development

# 1. PostgreSQL + TimescaleDB (All data: users, rooms, messages)
DB_HOST=localhost
DB_PORT=5432
DB_USER=chat_user
DB_PASSWORD=chat_pass
DB_NAME=chat_db
DB_SSLMODE=disable

# 3. Redis Settings (Session storage & cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. NATS Broker (WSS Pub/Sub JetStream)
NATS_URL=nats://localhost:4222

# 5. Meilisearch (Full-text Search engine)
MEILI_URL=http://localhost:7700
MEILI_KEY=meili_master_key_123456

# 6. MinIO S3 Emulator (Object storage)
MINIO_ENDPOINT=localhost:9005
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_pass
MINIO_USE_SSL=false
MINIO_BUCKET=chat-attachments

# 7. LiveKit Server (WebRTC Calls API)
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secretkey123456

# 8. JWT Cryptography (RS256 Keys path)
JWT_PRIVATE_KEY_PATH=keys/app.rsa
JWT_PUBLIC_KEY_PATH=keys/app.rsa.pub
